# Database
DATABASE_URL="postgresql://user@localhost:5432/pyxis?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# AWS S3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="pyxis-files"
S3_ENDPOINT=""  # Set to http://localhost:9000 for MinIO

# Session
SESSION_SECRET="change-this-to-a-random-secret"

# Auth
DEV_BYPASS_AUTH="false"

# Server
NODE_ENV="development"
PORT=4000
